{
    "terminal.integrated.cwd": "${workspaceFolder}",
    "files.associations": {
        "*.ch": "c"
    },
    "actionButtons": {

        "defaultColor": "white",
        "reloadButton": "↻",
        "loadNpmCommands": false,
        "commands": [
            {
                "name": "$(tools) Build Assembler",
                "color": "lime",
                "singleInstance": true,
                "command": "./compile.ps1 -mode buildAssembler", // This is executed in the terminal.
            },
            {
                "name": "$(tools) Build Emulator",
                "color": "aqua",
                "singleInstance": true,
                "command": "./compile.ps1 -mode buildEmulator", // This is executed in the terminal.
            },
            {
                "name": "$(triangle-right) Run Assembler",
                "color": "purple",
                "singleInstance": true,
                "command": "./compile.ps1 -mode runAssembler -codePath assets/numberInput.txt", // This is executed in the terminal.
            },
            {
                "name": "$(triangle-right) Run Emulator",
                "color": "darkblue",
                "singleInstance": true,
                "command": "./compile.ps1 -mode runEmulator", // This is executed in the terminal.
            }
        ]
    },
    "C_Cpp.default.compilerPath": "C:/msys64/ucrt64/bin/gcc.exe"
}